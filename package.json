{
  "name": "tink-harness",
  "version": "1.18.1",
  "description": "Self-growing harnesses for Claude Code and Codex.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "tink-harness": "bin/install.js"
  },
  "files": [
    "bin/",
    "templates/",
    ".claude-plugin/",
    "commands/",
    "skills/",
    "hooks/",
    "geobench/",
    "docs/*.md",
    "docs/pr/",
    "README.md",
    "CHANGELOG.md",
    "VERSIONING.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "npm run test:templates && npm run test:syntax && npm run test:metadata",
    "test:templates": "python tests/test_templates.py",
    "test:syntax": "node --check bin/install.js",
    "test:metadata": "node tests/test_metadata.mjs",
    "test:pack": "node tests/test_pack.mjs",
    "test:e2e": "node tests/test_install_smoke.mjs && node tests/test_update_preservation.mjs && node tests/test_codex_home.mjs",
    "check": "npm test && npm run test:pack"
  },
  "keywords": [
    "claude-code",
    "codex",
    "ai-agents",
    "agent-harness",
    "developer-tools",
    "cli",
    "automation",
    "agentic-coding",
    "llm",
    "workflow-automation",
    "code-agents",
    "hooks",
    "skills"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dotoricode/tink-harness.git"
  },
  "bugs": {
    "url": "https://github.com/dotoricode/tink-harness/issues"
  },
  "homepage": "https://github.com/dotoricode/tink-harness#readme",
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "picocolors": "^1.1.1"
  }
}
