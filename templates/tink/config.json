  "version": 1,
  "context_mode": "compact",
  "prefer_existing_harnesses": true,
  "read_runs_by_default": false,
  "save_new_harnesses_after_approval": true,
  "tone": "calm",
  "humor": "off",
  "language": "auto",
  "install_scope": "repo",
  "hook_scope": "off",
  "default_harnesses_per_task": 4,
  "harness_lines_warning": 100,
  "context_budget": "soft",
  "runs_ttl_days": 30,
  "runs_ttl_count": 20,
  "memory_has_entries": {
    "mistakes": false,
    "preferences": false,
    "lessons": false
  }
}
