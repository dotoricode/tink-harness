{
  "repo": "tink-harness",
  "version": 1,
  "purpose": "Static repo signal fixture for cast context selection. This is not a generated index and does not require a `tink index` command.",
  "verification_commands": [
    {
      "name": "test suite",
      "command": "npm test",
      "covers": [
        "template sync",
        "package contents",
        "installer output",
        "schema shape",
        "command surface"
      ]
    }
  ],
  "instruction_files": [
    {
      "path": "AGENTS.md",
      "reason": "Project instructions, including command sync rules and version bump policy."
    },
    {
      "path": "CONTEXT.md",
      "reason": "Tink domain glossary and operating concepts."
    },
    {
      "path": "docs/graph-contracts-and-guards.md",
      "reason": "Existing design note for contract, rule graph, verify, and guard behavior."
    },
    {
      "path": "docs/hooks.md",
      "reason": "Hook recommendation and opt-in guard policy."
    },
    {
      "path": "docs/memory.md",
      "reason": "Memory save boundaries and approved-memory policy."
    }
  ],
  "sync_groups": [
    {
      "name": "cast-command",
      "kind": "claude-command",
      "rule": "byte-identical",
      "files": [
        "commands/cast.md",
        "templates/claude/commands/tink/cast.md",
        ".claude/commands/tink/cast.md"
      ],
      "verified_by": "test_dual_format_paths_stay_in_sync"
    },
    {
      "name": "deep-cast-command",
      "kind": "claude-command",
      "rule": "byte-identical",
      "files": [
        "commands/deep-cast.md",
        "templates/claude/commands/tink/deep-cast.md",
        ".claude/commands/tink/deep-cast.md"
      ],
      "verified_by": "test_dual_format_paths_stay_in_sync"
    },
    {
      "name": "verify-command",
      "kind": "claude-command",
      "rule": "byte-identical",
      "files": [
        "commands/verify.md",
        "templates/claude/commands/tink/verify.md",
        ".claude/commands/tink/verify.md"
      ],
      "verified_by": "test_dual_format_paths_stay_in_sync"
    },
    {
      "name": "frog-command",
      "kind": "claude-command",
      "rule": "byte-identical",
      "files": [
        "commands/frog.md",
        "templates/claude/commands/tink/frog.md",
        ".claude/commands/tink/frog.md"
      ],
      "verified_by": "test_dual_format_paths_stay_in_sync"
    },
    {
      "name": "weave-command",
      "kind": "claude-command",
      "rule": "byte-identical",
      "files": [
        "commands/weave.md",
        "templates/claude/commands/tink/weave.md",
        ".claude/commands/tink/weave.md"
      ],
      "verified_by": "test_dual_format_paths_stay_in_sync"
    },
    {
      "name": "tink-claude-skill",
      "kind": "claude-skill",
      "rule": "byte-identical",
      "files": [
        "skills/tink/SKILL.md",
        "templates/claude/skills/tink/SKILL.md"
      ],
      "verified_by": "test_dual_format_paths_stay_in_sync"
    }
  ],
  "schema_files": [
    "templates/tink/schemas/contract.schema.json",
    "templates/tink/schemas/context-map.schema.json",
    "templates/tink/schemas/context-metrics-evaluation.schema.json",
    "templates/tink/schemas/verification.schema.json",
    "templates/tink/schemas/session.schema.json",
    "templates/tink/schemas/mcp-policy.schema.json",
    "templates/tink/schemas/harness-lifecycle.schema.json"
  ],
  "context_budget_policy": {
    "target_threshold_percent": 90,
    "entry_fields": [
      "role",
      "cost",
      "reuse_signal",
      "verification_link",
      "staleness",
      "evidence_kind"
    ],
    "role_defaults": [
      {
        "role": "primary",
        "meaning": "Required to understand or implement the active task."
      },
      {
        "role": "supporting",
        "meaning": "Useful because a repo signal links it to the active task."
      },
      {
        "role": "verification_target",
        "meaning": "Must connect to a command, manual check, or evidence ref."
      },
      {
        "role": "avoid_next_time",
        "meaning": "Should be excluded faster in similar future runs unless the task changes."
      }
    ],
    "scoring_basis": [
      "included entries with role and verification_link",
      "excluded entries with reuse_signal avoid_next_time",
      "verification_target entries with matching checks",
      "context-diff late additions and exclusions"
    ],
    "reason": "Context entries need stable roles and verification links before efficiency can be measured toward the 90 percent target."
  },
  "verification_hints": [
    {
      "name": "command-template-sync",
      "when": {
        "paths": [
          "commands/*.md",
          "templates/claude/commands/tink/*.md",
          ".claude/commands/tink/*.md"
        ],
        "signal_refs": [
          "sync_groups.*-command"
        ]
      },
      "add_manual_check": {
        "name": "command/template sync",
        "target": "test_dual_format_paths_stay_in_sync",
        "required": true
      },
      "reason": "Command copies must stay byte-identical across root and installer template surfaces."
    },
    {
      "name": "claude-skill-sync",
      "when": {
        "paths": [
          "skills/tink/SKILL.md",
          "templates/claude/skills/tink/SKILL.md"
        ],
        "signal_refs": [
          "sync_groups.tink-claude-skill"
        ]
      },
      "add_manual_check": {
        "name": "Claude skill sync",
        "target": "test_dual_format_paths_stay_in_sync",
        "required": true
      },
      "reason": "Root and installable Claude Tink skill files must stay byte-identical."
    },
    {
      "name": "schema-shape",
      "when": {
        "paths": [
          "templates/tink/schemas/*.json"
        ],
        "signal_refs": [
          "schema_files"
        ]
      },
      "add_manual_check": {
        "name": "schema shape",
        "target": "test_contract_rule_graph_and_verify_templates_exist",
        "required": true
      },
      "reason": "Schema changes should be checked for required fields and JSON shape."
    },
    {
      "name": "command-surface",
      "when": {
        "paths": [
          "commands/*.md",
          "templates/claude/commands/tink/*.md",
          ".claude/commands/tink/*.md",
          "templates/codex/skills/tink-*/SKILL.md"
        ],
        "signal_refs": [
          "command_surface"
        ]
      },
      "add_manual_check": {
        "name": "command surface stays focused",
        "target": "test_command_surface_is_focused",
        "required": true
      },
      "reason": "Command additions and aliases should not expand the public surface by accident."
    },
    {
      "name": "installer-update-confidence",
      "when": {
        "paths": [
          "bin/install.js",
          "package.json",
          "README.md",
          "README.ko.md",
          "docs/update-*.md"
        ],
        "signal_refs": [
          "context_graph_lite.rules.installer-update-flow"
        ]
      },
      "add_manual_check": {
        "name": "installer update confidence",
        "target": "test_codex_update_refreshes_existing_install",
        "required": true
      },
      "reason": "Installer, package, README, and update docs changes should prove existing-user update behavior still preserves local state and reports the result clearly."
    }
  ],
  "context_graph_lite": {
    "mode": "internal-cast-only",
    "public_command": false,
    "description": "Small static changed-path rules used by cast to choose related context. This is not a generated index and must not add a public command.",
    "rules": [
      {
        "name": "claude-command-sync",
        "when_paths": [
          "commands/*.md",
          "templates/claude/commands/tink/*.md",
          ".claude/commands/tink/*.md"
        ],
        "include_paths": [
          "commands/cast.md",
          "templates/claude/commands/tink/cast.md",
          ".claude/commands/tink/cast.md",
          "tests/test_templates.py"
        ],
        "signal_refs": [
          "sync_groups.*-command",
          "verification_hints.command-template-sync",
          "verification_hints.command-surface"
        ],
        "reason": "Claude command edits often require the matching command copies and sync tests.",
        "confidence": "high"
      },
      {
        "name": "codex-skill-surface",
        "when_paths": [
          "templates/codex/skills/tink-*/SKILL.md",
          "templates/codex/skills/tink-core/RULES.md"
        ],
        "include_paths": [
          "templates/codex/skills/tink-core/RULES.md",
          "templates/codex/skills/tink-cast/SKILL.md",
          "tests/test_templates.py",
          "docs/compatibility-policy.md"
        ],
        "signal_refs": [
          "verification_hints.command-surface"
        ],
        "reason": "Codex skill edits can affect picker surface, shared rules, and Claude/Codex compatibility.",
        "confidence": "high"
      },
      {
        "name": "installer-update-flow",
        "when_paths": [
          "bin/install.js",
          "package.json",
          "README.md",
          "README.ko.md",
          "docs/update-*.md"
        ],
        "include_paths": [
          "bin/install.js",
          "tests/test_templates.py",
          "README.md",
          "README.ko.md",
          "docs/update-troubleshooting.md",
          "docs/update-troubleshooting.ko.md",
          "docs/update-verification-recipe.md",
          "docs/update-verification-recipe.ko.md"
        ],
        "signal_refs": [
          "verification_commands.test suite",
          "verification_hints.installer-update-confidence"
        ],
        "reason": "Installer and update docs should be checked together because update output, package contents, and user guidance must stay aligned.",
        "confidence": "high"
      },
      {
        "name": "schema-contract-artifacts",
        "when_paths": [
          "templates/tink/schemas/*.json",
          "tests/fixtures/current-run/*.json"
        ],
        "include_paths": [
          "templates/tink/schemas/contract.schema.json",
          "templates/tink/schemas/context-map.schema.json",
          "templates/tink/schemas/verification.schema.json",
          "templates/tink/schemas/session.schema.json",
          "tests/fixtures/current-run/context-map.json",
          "tests/fixtures/current-run/contract.json",
          "tests/test_templates.py"
        ],
        "signal_refs": [
          "schema_files",
          "verification_hints.schema-shape"
        ],
        "reason": "Schema and current-run fixture changes should keep artifact shape, contract checks, and tests together.",
        "confidence": "high"
      }
    ]
  },
  "fixture_dirs": [
    {
      "path": "tests/fixtures/current-run",
      "reason": "Dogfood fixtures for current-run context artifacts."
    }
  ],
  "command_surface": {
    "allowed": [
      "setup.md",
      "cast.md",
      "deep-cast.md",
      "verify.md",
      "list.md",
      "frog.md",
      "weave.md",
      "update.md"
    ],
    "forbidden": [
      "index.md",
      "tink-index.md"
    ],
    "verified_by": "test_command_surface_is_focused"
  }
}
